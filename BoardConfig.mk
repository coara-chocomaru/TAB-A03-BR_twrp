DEVICE_PATH := device/sts/a03br
BOARD_VENDOR := sts
BOARD_DEVICE := a03br
TARGET_DEVICE := a03br
TARGET_SOC := pxa1928
TARGET_BOARD_PLATFORM := mrvl
BOARD_USES_MRVL_HARDWARE := true

# Build options
ALLOW_MISSING_DEPENDENCIES := true
BOARD_SUPPRESS_SECURE_ERASE := true
# BOARD_NO_SECURE_DISCARD := true
TARGET_OTA_ASSERT_DEVICE := TAB-A03-BR,a03br

# Disabled features
BOARD_PROVIDES_LIBRIL := false
BOARD_PROVIDES_RILD := false
BOARD_HAS_NFC := false
BOARD_HAS_RADIO := false
BOARD_HAS_HDMI := false
WITHOUT_CHECK_API := true

# Architecture
TARGET_ARCH := arm64
TARGET_ARCH_VARIANT := armv8-a
TARGET_CPU_ABI := arm64-v8a
TARGET_CPU_ABI2 :=
TARGET_CPU_VARIANT := generic
TARGET_CPU_VARIANT_RUNTIME := cortex-a53
TARGET_CPU_SMP := true

TARGET_2ND_ARCH := arm
TARGET_2ND_ARCH_VARIANT := armv7-a-neon
TARGET_2ND_CPU_ABI := armeabi-v7a
TARGET_2ND_CPU_ABI2 := armeabi
TARGET_2ND_CPU_VARIANT := generic
TARGET_2ND_CPU_VARIANT_RUNTIME := cortex-a53
TARGET_CPU_ABI_LIST_64_BIT := $(TARGET_CPU_ABI)
TARGET_CPU_ABI_LIST_32_BIT := $(TARGET_2ND_CPU_ABI),$(TARGET_2ND_CPU_ABI2)
TARGET_CPU_ABI_LIST := $(TARGET_CPU_ABI_LIST_64_BIT),$(TARGET_CPU_ABI_LIST_32_BIT)
TARGET_CPU_MEMCPY_OPT_DISABLE := true
ARCH_ARM_HAVE_TLS_REGISTER := true
TARGET_SCREEN_DENSITY := 160

# OTA

AB_OTA_UPDATER := false

# Bootloader

TARGET_BOOTLOADER_BOARD_NAME := TAB-A03-BR
TARGET_NO_FACTORYIMAGE :=true
TARGET_NO_BOOTLOADER := true
TARGET_NO_RADIOIMAGE := true

# Display

DEVICE_RESOLUTION := 1280x800
LANDSCAPE_RESOLUTION := 1280x800
PORTRAIT_RESOLUTION := 800x1280
NUM_FRAMEBUFFER_SURFACE_BUFFERS := 2
TARGET_RECOVERY_PIXEL_FORMAT := "BGRA_8888"
TARGET_DISABLE_TRIPLE_BUFFERING := true
# Properties

TARGET_SYSTEM_PROP := $(DEVICE_PATH)/system.prop

# File systems

BOARD_HAS_LARGE_FILESYSTEM := true

# BOARD_RECOVERYIMAGE_PARTITION_SIZE := 10485760

BOARD_RECOVERYIMAGE_PARTITION_SIZE := 16777216
BOARD_FLASH_BLOCK_SIZE := 131072
BOARD_BOOTIMAGE_PARTITION_SIZE := 16777216
BOARD_SYSTEMIMAGE_PARTITION_SIZE := 1988100096
BOARD_SYSTEMIMAGE_PARTITION_TYPE := ext4
BOARD_USERDATAIMAGE_FILE_SYSTEM_TYPE := ext4
BOARD_UMS_LUNFILE := "/sys/class/android_usb/f_mass_storage/lun0/file"
BOARD_USES_MMCUTILS := true
BOARD_HAS_NO_MISC_PARTITION := true

# Kernel

BOARD_KERNEL_BASE := 0x10000000
BOARD_KERNEL_CMDLINE :=
BOARD_KERNEL_PAGESIZE := 2048
BOARD_RAMDISK_OFFSET := 0x01000000
BOARD_KERNEL_TAGS_OFFSET := 0x00000100
BOARD_KERNEL_OFFSET := 0x00008000
BOARD_SECOND_OFFSET := 0x00f00000

BOARD_MKBOOTIMG_ARGS := \
     --base $(BOARD_KERNEL_BASE) \
     --pagesize $(BOARD_KERNEL_PAGESIZE) \
     --kernel_offset $(BOARD_KERNEL_OFFSET) \
     --ramdisk_offset $(BOARD_RAMDISK_OFFSET) \
     --tags_offset $(BOARD_KERNEL_TAGS_OFFSET) \
     --second_offset $(BOARD_SECOND_OFFSET) \
     --cmdline "$(BOARD_KERNEL_CMDLINE)"

# Kernel - prebuilt
TARGET_FORCE_PREBUILT_KERNEL := true
ifeq ($(TARGET_FORCE_PREBUILT_KERNEL),true)
TARGET_PREBUILT_KERNEL := $(DEVICE_PATH)/prebuilt/kernel
PRODUCT_COPY_FILES += \
    $(DEVICE_PATH)/prebuilt/kernel:kernel
endif


# Recovery

TARGET_USERIMAGES_USE_EXT4 := true
RECOVERY_SDCARD_ON_DATA := true
BOARD_RECOVERY_SWIPE := true
BOARD_SUPPRESS_EMMC_WIPE := true
TARGET_USE_CUSTOM_LUN_FILE_PATH := "/sys/class/android_usb/f_mass_storage/lun%d/file"
TARGET_RECOVERY_FSTAB := $(DEVICE_PATH)/recovery/root/etc/recovery.fstab
TARGET_RECOVERY_DEVICE_DIRS += $(DEVICE_PATH)
BOARD_HAS_NO_REAL_SDCARD := true
TW_NO_EXFAT := true
RECOVERY_FSTAB_VERSION := 2
RECOVERY_TOUCHSCREEN_SWAP_XY := false
RECOVERY_TOUCHSCREEN_FLIP_X := false
RECOVERY_TOUCHSCREEN_FLIP_Y := false
RECOVERY_TOUCHSCREEN_FLIP_XY := false
TW_X_OFFSET := 0
TW_Y_OFFSET := -13
TW_W_OFFSET := -13
TW_H_OFFSET := 0

SELINUX_IGNORE_NEVERALLOWS := true
BOARD_HAS_NO_SELECT_BUTTON := true
TW_NO_BATT_PERCENT := true
TW_BRIGHTNESS_PATH := /sys/devices/platform/panel_vx5b1d.19/backlight/lcd-bl/brightness
TW_MAX_BRIGHTNESS := 255
TW_DEFAULT_BRIGHTNESS := 128 
TW_USE_TOOLBOX := false
TW_THEME := landscape_mdpi
TW_SCREEN_WIDTH := 1280
TW_SCREEN_HEIGHT := 800
TW_EXTRA_LANGUAGES := false
TW_USE_INPUT_EVENTS := true
TW_INCLUDE_INJECTTWRP := false
# TW_INPUT_BLACKLIST := hbtp_vm
TW_INPUT_BLACKLIST := "isl29023\x0alsm9ds1_mag"
TW_NO_SCREEN_TIMEOUT := true
TW_EXCLUDE_BASH := true
TW_EXCLUDE_NANO := true
TW_EXCLUDE_LZMA := true
TW_EXCLUDE_SED := true
TW_EXCLUDE_MTP := true
TW_NO_BZIP2 := true
# TW_EXCLUDE_DEFAULT_USB_INIT := true

TW_EXCLUDE_TAR := true
TW_EXCLUDE_ENCRYPTED_BACKUPS := true
TW_EXCLUDE_TWRPAPP := true
TW_EXCLUDE_SUPERSU := true
TW_EXCLUDE_PYTHON := true
TW_DEFAULT_LANGUAGE := en
TW_EXCLUDE_GZIP := true
TW_EXCLUDE_XZ := true
TW_NO_CPU_TEMP := true
TW_NO_HAPTICS := true
TW_ALWAYS_RMRF := true
TW_EXCLUDE_TZDATA := true
TW_NO_EXFAT_FUSE := true
TW_NO_USB_STORAGE := true
TARGET_USES_LOGD := false
TWRP_INCLUDE_LOGCAT := false
TW_NO_REBOOT_BOOTLOADER := true
TW_INTERNAL_STORAGE_PATH := "/data/media/0"
TW_INTERNAL_STORAGE_MOUNT_POINT := "data"
TW_EXTERNAL_STORAGE_PATH := "/external_sd"
TW_EXTERNAL_STORAGE_MOUNT_POINT := "external_sd"
